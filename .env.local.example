# === SUPABASE ===
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# === AI ===
ANTHROPIC_API_KEY=
# OpenAI is used as the circuit-breaker fallback when Claude is unavailable.
# Without this, AI_FORCE_FALLBACK has no effect and forced-fallback calls fail.
OPENAI_API_KEY=
# Set '1' (or 'true'/'yes') to always route AI calls through OpenAI — useful
# for debugging the fallback path without tripping the circuit breaker.
AI_FORCE_FALLBACK=
# Set '1' to disable the OpenAI fallback entirely so all calls fail fast when
# Claude is unavailable (useful in cost-sensitive or compliance environments).
AI_DISABLE_FALLBACK=

# === GOOGLE (Gmail OAuth) ===
# Used by /api/gmail/oauth/start + /api/gmail/oauth/callback (GAP-13).
# Obtain at https://console.cloud.google.com/apis/credentials. Add the
# GOOGLE_OAUTH_REDIRECT_URI value below to the OAuth client's "Authorized
# redirect URIs" list.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Optional explicit override. If unset, the callback infers
# `${origin}/api/gmail/oauth/callback`. Set this in production so behind-
# proxy or custom-domain deployments don't infer the wrong origin.
GOOGLE_OAUTH_REDIRECT_URI=
# HMAC key used to sign the OAuth `state` parameter so the callback can
# trust venue_id + user_id without round-tripping through the database.
# REQUIRED in production. Must be at least 16 chars. Rotate by setting a
# new value — outstanding OAuth flows fail open with `bad_state_bad_signature`.
STATE_SIGNING_SECRET=

# === EXTERNAL DATA ===
NOAA_CDO_TOKEN=
FRED_API_KEY=
# SerpAPI powers the wedding-trend fetcher in lib/services/trends.ts.
# Without it, both fetchTrendsForVenue and fetchTrendsForAllVenues log a
# warning and return early — Sage intelligence context loses its "couples
# in your market are searching for X" signal. Get a key at
# https://serpapi.com (free tier = 100 searches/month, plenty for daily
# trend refreshes across a handful of venues). The var name must match
# Vercel's existing entry exactly — SERPAPI_API_KEY (not SERPAPI_KEY).
SERPAPI_API_KEY=

# Optional. Census ACS5 queries work without a key but are rate-limited. Request one at https://api.census.gov/data/key_signup.html
CENSUS_API_KEY=

# === MULTI-TENANT ROUTING ===
# Base domain used in middleware to derive per-venue subdomains.
# In dev this is typically 'localhost:3000'; in prod it should be your apex domain.
# Falls back to 'bloomhouse.ai' if unset — set it explicitly in production.
NEXT_PUBLIC_BASE_DOMAIN=localhost:3000

# === AUTH ===
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# === ZOOM ===
# Zoom OAuth app credentials for the Zoom meeting-link integration.
# Create an app at https://marketplace.zoom.us → Build App → OAuth.
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=
# The redirect URI registered in your Zoom OAuth app.
# Must match exactly — e.g. https://yourapp.com/api/auth/zoom/callback
ZOOM_REDIRECT_URI=
# HMAC secret used to sign the Zoom OAuth `state` parameter (CSRF protection).
# Falls back to NEXTAUTH_SECRET → CRON_SECRET in order; set explicitly in prod.
# Generate with: openssl rand -hex 32
ZOOM_STATE_SECRET=

# === CALENDLY ===
# Personal API token for the single-tenant fallback (used if no per-venue OAuth
# token exists in the DB). Generate at https://calendly.com/integrations/api_webhooks
CALENDLY_API_TOKEN=
# Calendly OAuth app credentials for multi-venue connections.
# Create an app at https://developer.calendly.com → OAuth Applications.
CALENDLY_OAUTH_CLIENT_ID=
CALENDLY_OAUTH_CLIENT_SECRET=
# Signing key for validating Calendly webhook payloads.
# Found under your Calendly webhook subscription settings.
CALENDLY_WEBHOOK_SECRET=

# === CRON ===
CRON_SECRET=

# === TRANSACTIONAL EMAIL (Resend) ===
# Used for couple invitations and as a fallback for daily digests when a
# venue's Gmail isn't connected. If RESEND_API_KEY is blank, sendEmail
# falls back to console.log so local dev still works.
RESEND_API_KEY=
EMAIL_FROM=The Bloom House <hello@thebloomhouse.ai>

# === DEMO ===
# Demo mode is cookie-based — visit /demo to activate. The demo cookie is now
# HMAC-signed server-side; this secret is REQUIRED for the /demo entry to work.
# Generate with: openssl rand -hex 32
DEMO_SIGNING_SECRET=

# === FEATURE FLAGS ===
# Set '1' to use cluster-level first-touch attribution instead of per-lead first touch.
# Affects attribution-parity computation (lib/services/attribution-parity.ts).
USE_CLUSTER_FIRST_TOUCH=
# Set '1' to suppress heat-map signals whose confidence score is below threshold.
# When unset, all signals fire regardless of confidence (lib/services/anomaly-detection.ts).
HEAT_RESPECTS_CONFIDENCE=

# === TEST / E2E ===
# Secret required to call the test-harness endpoint (/api/admin/test-harness).
# Never expose in production; route is guarded to non-prod only.
# Generate with: openssl rand -hex 32
TEST_HARNESS_SECRET=
# Base URL for the E2E data-flow test script (scripts/e2e-data-flow-test.mjs).
# If unset, the script defaults to http://localhost:<E2E_PORT>.
E2E_BASE_URL=
# Port the local dev server listens on during E2E tests. Defaults to 3100.
E2E_PORT=3100

# === SCRIPTS ===
# Venue UUID for one-off Rixey scripts (scripts/recover-gmail-window.ts).
# Falls back to the hardcoded Rixey venue ID if unset.
RIXEY_VENUE_ID=f3d10226-4c5c-47ad-b89b-98ad63842492
# Base URL for verification scripts that hit the live app API
# (scripts/rixey-load/57-jjj-verify.ts, 61-kkk-verify.ts).
# Leave unset to skip the live-endpoint checks in those scripts.
BLOOM_BASE_URL=
# Session cookie value for live-endpoint checks in verification scripts.
# Set to the value of your browser session cookie after logging in.
# Leave unset to skip authenticated checks.
BLOOM_COOKIE=

# === STRIPE ===
# Secret + webhook secret. Use sk_test_/whsec_ in dev, sk_live_/whsec_ in prod.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Price IDs for subscription plans. Create these in the Stripe dashboard.
# "Intelligence" = mid tier, "Enterprise" = top tier. Starter is free (no price).
STRIPE_PRICE_INTELLIGENCE_MONTHLY=price_xxx
STRIPE_PRICE_INTELLIGENCE_ANNUAL=price_xxx
STRIPE_PRICE_ENTERPRISE_MONTHLY=price_xxx
STRIPE_PRICE_ENTERPRISE_ANNUAL=price_xxx
# Public base URL for building success/cancel URLs. Falls back to request origin.
NEXT_PUBLIC_APP_URL=http://localhost:3000
