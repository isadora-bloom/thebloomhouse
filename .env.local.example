# === SUPABASE ===
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# === AI ===
ANTHROPIC_API_KEY=

# === GOOGLE (Gmail OAuth) ===
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# === EXTERNAL DATA ===
NOAA_CDO_TOKEN=
FRED_API_KEY=

# === AUTH ===
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# === CRON ===
CRON_SECRET=

# === TRANSACTIONAL EMAIL (Resend) ===
# Used for couple invitations and as a fallback for daily digests when a
# venue's Gmail isn't connected. If RESEND_API_KEY is blank, sendEmail
# falls back to console.log so local dev still works.
RESEND_API_KEY=
EMAIL_FROM=The Bloom House <hello@thebloomhouse.com>

# === DEMO ===
# Demo mode is cookie-based — visit /demo to activate. No env var needed.
