# === SUPABASE ===
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# === AI ===
ANTHROPIC_API_KEY=

# === GOOGLE (Gmail OAuth) ===
# Used by /api/gmail/oauth/start + /api/gmail/oauth/callback (GAP-13).
# Obtain at https://console.cloud.google.com/apis/credentials. Add the
# GOOGLE_OAUTH_REDIRECT_URI value below to the OAuth client's "Authorized
# redirect URIs" list.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Optional explicit override. If unset, the callback infers
# `${origin}/api/gmail/oauth/callback`. Set this in production so behind-
# proxy or custom-domain deployments don't infer the wrong origin.
GOOGLE_OAUTH_REDIRECT_URI=
# HMAC key used to sign the OAuth `state` parameter so the callback can
# trust venue_id + user_id without round-tripping through the database.
# REQUIRED in production. Must be at least 16 chars. Rotate by setting a
# new value — outstanding OAuth flows fail open with `bad_state_bad_signature`.
STATE_SIGNING_SECRET=

# === EXTERNAL DATA ===
NOAA_CDO_TOKEN=
FRED_API_KEY=
# SerpAPI powers the wedding-trend fetcher in lib/services/trends.ts.
# Without it, both fetchTrendsForVenue and fetchTrendsForAllVenues log a
# warning and return early — Sage intelligence context loses its "couples
# in your market are searching for X" signal. Get a key at
# https://serpapi.com (free tier = 100 searches/month, plenty for daily
# trend refreshes across a handful of venues). The var name must match
# Vercel's existing entry exactly — SERPAPI_API_KEY (not SERPAPI_KEY).
SERPAPI_API_KEY=

# Optional. Census ACS5 queries work without a key but are rate-limited. Request one at https://api.census.gov/data/key_signup.html
CENSUS_API_KEY=

# === AUTH ===
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# === CRON ===
CRON_SECRET=

# === TRANSACTIONAL EMAIL (Resend) ===
# Used for couple invitations and as a fallback for daily digests when a
# venue's Gmail isn't connected. If RESEND_API_KEY is blank, sendEmail
# falls back to console.log so local dev still works.
RESEND_API_KEY=
EMAIL_FROM=The Bloom House <hello@thebloomhouse.ai>

# === DEMO ===
# Demo mode is cookie-based — visit /demo to activate. No env var needed.

# === STRIPE ===
# Secret + webhook secret. Use sk_test_/whsec_ in dev, sk_live_/whsec_ in prod.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Price IDs for subscription plans. Create these in the Stripe dashboard.
# "Intelligence" = mid tier, "Enterprise" = top tier. Starter is free (no price).
STRIPE_PRICE_INTELLIGENCE_MONTHLY=price_xxx
STRIPE_PRICE_INTELLIGENCE_ANNUAL=price_xxx
STRIPE_PRICE_ENTERPRISE_MONTHLY=price_xxx
STRIPE_PRICE_ENTERPRISE_ANNUAL=price_xxx
# Public base URL for building success/cancel URLs. Falls back to request origin.
NEXT_PUBLIC_APP_URL=http://localhost:3000
